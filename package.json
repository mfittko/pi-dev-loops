{
  "name": "pi-dev-loops",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Shared Pi workflow infrastructure for reusable local and remote development loops",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "workflow",
    "dev-loop",
    "github",
    "copilot"
  ],
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test:assets && npm run test:extension && npm run test:scripts && npm run test:core",
    "test:assets": "node --test test/imported-assets-normalization.test.mjs test/refiner-agent-phase-planning.test.mjs test/dev-loop-init-phase-smoke.test.mjs test/ui-validation-contract.test.mjs",
    "test:extension": "node --import tsx --test test/extension-checks.test.mjs test/extension-installer.test.mjs test/extension-command-contract.test.mjs test/extension-package-contract.test.mjs test/dev-loops-core.test.mjs test/dev-loops-cli.test.mjs",
    "test:scripts": "node --test test/github/*.test.mjs test/loop/*.test.mjs",
    "test:core": "node --test packages/core/test/*.test.mjs",
    "test:dev-loop": "npm --prefix skills/dev-loop test",
    "playwright:install:safari": "playwright install webkit",
    "test:playwright:viewer": "playwright test -c playwright.inspect-run-viewer.config.mjs",
    "repo-wiki:prepare": "node scripts/repo-wiki-local.mjs prepare",
    "repo-wiki:init": "node scripts/repo-wiki-local.mjs init --repo .",
    "repo-wiki:scan": "node scripts/repo-wiki-local.mjs scan --repo . --out .llmwiki/run",
    "repo-wiki:plan": "node scripts/repo-wiki-local.mjs plan --scan .llmwiki/run --out .llmwiki/bootstrap-plan.json",
    "repo-wiki:compile": "node scripts/repo-wiki-local.mjs compile --scan .llmwiki/run --plan .llmwiki/bootstrap-plan.json --wiki .llmwiki/wiki",
    "repo-wiki:lint-docs": "node scripts/repo-wiki-local.mjs lint-docs --repo . --scan .llmwiki/run",
    "repo-wiki:bootstrap": "npm run repo-wiki:scan && npm run repo-wiki:plan && npm run repo-wiki:compile",
    "repo-wiki:search": "node scripts/repo-wiki-local.mjs search --wiki .llmwiki/wiki"
  },
  "bin": {
    "pi-dev-loops": "./bin/pi-dev-loops.mjs"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "tsx": "^4.22.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "mermaid": "11.15.0"
  }
}
