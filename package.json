{
  "name": "pi-dev-loops",
  "private": true,
  "type": "module",
  "description": "Shared Pi workflow infrastructure for reusable local and remote development loops",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "workflow",
    "dev-loop",
    "github",
    "copilot"
  ],
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test:assets": "node --test test/imported-assets-normalization.test.mjs test/refiner-agent-phase-planning.test.mjs test/dev-loop-init-phase-smoke.test.mjs",
    "test:core": "node --test packages/core/test/*.test.mjs",
    "test:dev-loop": "npm --prefix skills/dev-loop test"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
